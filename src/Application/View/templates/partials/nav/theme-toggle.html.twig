{#
 # Light/dark skin-mode toggle control used in the marketing demo-nav.
 # Emits the unified skin-mode attributes consumed by every site's
 # `Static/js/site.js`. No per-site prefix.
 #}
<div class="demo-nav__theme-control">
    <span class="demo-nav__theme-text" aria-hidden="true" data-skin-text>Dark mode</span>
    <button
        class="demo-nav__theme-toggle"
        type="button"
        aria-pressed="false"
        aria-label="Switch to dark mode"
        title="Toggle color theme"
        data-skin-toggle
    >
        <span class="demo-nav__theme-toggle-track" aria-hidden="true">
            <span class="demo-nav__theme-toggle-thumb"></span>
        </span>
    </button>
</div>
