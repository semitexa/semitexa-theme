<!doctype html>
<html lang="{{ app.request.locale ?? app.request.defaultLocale ?? 'en' }}">
  <head>
    <meta charset="utf-8" />
    <title>{% block title %}{{ title|default('Semitexa') }}{% endblock %}</title>
    <style>
      .layout{display:grid;grid-template-columns:minmax(220px,280px) minmax(0,1fr) minmax(220px,280px);gap:24px}
      @media (max-width: 900px){.layout{grid-template-columns:1fr}}
    </style>
    {{ semantic_head() }}
    {{ asset_head() }}
    {{ inject_scripts('head') }}
    {% block head_extra %}{{ layout_slot('head_extra') }}{% endblock %}
  </head>
  <body{{ __ssr_handle_attr|default('')|raw }}>
    <header>
      {% block header %}{{ layout_slot('header') }}{{ header|default('')|raw }}{% endblock %}
    </header>
    <nav class="breadcrumbs" aria-label="Breadcrumbs">
      {% block breadcrumbs %}{{ layout_slot('breadcrumbs') }}{{ breadcrumbs|default('')|raw }}{% endblock %}
    </nav>
    <div class="layout">
      <aside>
        {% block sidebar_left %}{{ layout_slot('sidebar_left') }}{{ sidebar_left|default('')|raw }}{% endblock %}
      </aside>
      <main>
        {% block main %}{{ layout_slot('main_before') }}{{ main|default(content|default(''))|raw }}{{ layout_slot('main_after') }}{% endblock %}
      </main>
      <aside>
        {% block sidebar_right %}{{ layout_slot('sidebar_right') }}{{ sidebar_right|default('')|raw }}{% endblock %}
      </aside>
    </div>
    <footer>
      {% block footer %}{{ layout_slot('footer') }}{{ footer|default('')|raw }}{{ layout_slot('footer_after') }}{% endblock %}
    </footer>
    {{ asset_body() }}
    {{ inject_scripts('body') }}
  </body>
</html>

